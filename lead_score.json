    "wkład własny",
    "okres leasingu",
    "forma działalności",
    "czas zakupu",
    "dane kontaktowe"
  ],
  "minimum_data_for_offer_ready_lead": [
    "przedmiot leasingu",
    "wartość lub budżet",
    "forma działalności",
    "okres leasingu lub preferowana rata"
  ],
  "response_strategy_by_band": {
    "Cold": {
      "tone": "spokojny, pomocny, nienachalny",
      "goal": "utrzymać rozmowę i zdobyć podstawowy kontekst",
      "questions_limit": 2
    },
    "Warm": {
      "tone": "konkretny, doradczy",
      "goal": "kwalifikacja leadu",
      "questions_limit": 4
    },
    "Hot": {
      "tone": "pewny, sprawny, sprzedażowy ale naturalny",
      "goal": "przejście do kalkulacji lub rozmowy telefonicznej",
      "questions_limit": 4
    },
    "Priority": {
      "tone": "bardzo konkretny, szybki, premium",
      "goal": "domknięcie kontaktu i przekazanie do handlowca",
      "questions_limit": 3
    }
  },
  "human_handoff_rules": [
    {
      "condition": "score >= 75",
      "action": "przekaż do handlowca natychmiast"
    },
    {
      "condition": "klient prosi o telefon lub ofertę",
      "action": "przekaż do handlowca"
    },
    {
      "condition": "wiadomość zawiera komplet danych do kalkulacji",
      "action": "przekaż do handlowca"
    }
  ],
  "output_format": {
    "fields": [
      "lead_score",
      "lead_label",
      "priority",
      "recommended_action",
      "intent_summary",
      "missing_data",
      "next_best_message"
    ]
  }
}
