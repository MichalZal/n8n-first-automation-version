{
  "system_name": "Leasing Lead Scoring Engine",
  "version": "1.0",
  "goal": "Ocena jakości leadu na podstawie wiadomości klienta w celu priorytetyzacji kontaktu handlowego i dopasowania stylu odpowiedzi.",
  "industry": "leasing",
  "language": "pl",
  "score_range": {
    "min": 0,
    "max": 100
  },
  "score_bands": [
    {
      "label": "Cold",
      "min": 0,
      "max": 24,
      "priority": "low",
      "recommended_action": "krótka odpowiedź informacyjna, bez presji sprzedażowej, próba doprecyzowania potrzeb"
    },
    {
      "label": "Warm",
      "min": 25,
      "max": 49,
      "priority": "medium",
      "recommended_action": "zadać 2-4 pytania kwalifikujące i zebrać podstawowe dane"
    },
    {
      "label": "Hot",
      "min": 50,
      "max": 74,
      "priority": "high",
      "recommended_action": "szybka odpowiedź, przejście do konkretów oferty i zebranie danych do kalkulacji"
    },
    {
      "label": "Priority",
      "min": 75,
      "max": 100,
      "priority": "urgent",
      "recommended_action": "natychmiastowy follow-up, propozycja telefonu lub przygotowania oferty tego samego dnia"
    }
  ],
  "dimensions": [
    {
      "name": "intent",
      "max_points": 35,
      "description": "Siła zamiaru zakupu lub wejścia w leasing"
    },
    {
      "name": "financial_fit",
      "max_points": 25,
      "description": "Czy lead brzmi realistycznie finansowo i biznesowo"
    },
    {
      "name": "timing",
      "max_points": 20,
      "description": "Jak szybko klient chce działać"
    },
    {
      "name": "completeness",
      "max_points": 10,
      "description": "Ile kluczowych danych klient podał od razu"
    },
    {
      "name": "conversation_quality",
      "max_points": 10,
      "description": "Czy wiadomość jest konkretna, spójna i użyteczna"
    }
  ],
